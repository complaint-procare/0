# Copy to .env.local and fill in values.
# These are exposed to the browser (Vite inlines anything prefixed with VITE_),
# so use the anon key — never the service_role key.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Google OAuth — public client_id only. The client_secret stays in Supabase secrets.
VITE_GOOGLE_OAUTH_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# Optional: base path for local production preview of GitHub Pages bundle
# VITE_BASE_PATH=/0/
